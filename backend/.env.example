# HolyRead Backend — config
# Copy to .env and fill in values

# CORS — comma-separated allowlist of origins.
# Leave EMPTY in dev: backend auto-allows localhost + private LANs (192.168.*, 10.*, etc).
# Set explicitly in production:
#   ALLOWED_ORIGINS=https://your-frontend.com,https://your-staging.com
ALLOWED_ORIGINS=

# Optional regex allowlist (overrides nothing; coexists with ALLOWED_ORIGINS).
# Example: ALLOWED_ORIGIN_REGEX=^https://.*\.your-domain\.com$
ALLOWED_ORIGIN_REGEX=

# Rate limit — global default (per IP)
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_SEARCH=20/minute

# Server
HOST=0.0.0.0
PORT=8000

# Data location (relative to backend/)
DATA_DIR=data
